# =============================================================
# Environment Variables — khai-claude Backend
# Copy this file to .env and fill in real values
# NEVER commit .env to git
# =============================================================

# --- Server ---
# Port the Express server listens on (Railway sets this automatically)
PORT=3000

# --- Database ---
# Full PostgreSQL connection string (from Railway / Render / Supabase)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- Authentication ---
# Secret key for signing JWT tokens — must be at least 32 random characters
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_this_to_a_random_secret_key_min_32_chars

# --- CORS ---
# Frontend origin allowed to call this API (no trailing slash)
FRONTEND_URL=https://kulchartt.github.io

# --- Anthropic AI ---
# Used by /api/ai (chat assistant) and /api/ekyc (ID verification)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# --- Cloudinary (image storage) ---
# Used for product image uploads (/api/products)
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
